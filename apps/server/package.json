{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@tardis/ai": "workspace:*",
    "@tardis/db": "workspace:*",
    "@tardis/env": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tardis/config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.7",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^4.1.7"
  }
}
